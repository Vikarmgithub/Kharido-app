<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6200EE"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="श्री मिष्ठान भंडार"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="स्मार्ट बिलिंग सिस्टम"
                android:textColor="#E1BEE7"
                android:textSize="12sp" />
        </LinearLayout>
        
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Settings"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Navigation Buttons Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="3dp">
        
        <Button
            android:id="@+id/btnShopView"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="🛍️ दुकान"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#6200EE"
            android:elevation="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btnDashView"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="📊 डैशबोर्ड"
            android:textColor="#6200EE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- Main Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Shop View (Products) -->
        <ScrollView
            android:id="@+id/shopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:padding="12dp"
            android:background="#F5F5F5">
            
            <LinearLayout
                android:id="@+id/shopProductList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp" />
        </ScrollView>

        <!-- Dashboard View -->
        <ScrollView
            android:id="@+id/dashboardContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:padding="12dp"
            android:background="#F5F5F5">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <!-- Dashboard Tab Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="#FFFFFF"
                    android:padding="8dp"
                    android:elevation="2dp">
                    
                    <Button
                        android:id="@+id/tabInventory"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginRight="4dp"
                        android:text="📦 स्टॉक"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:background="#03DAC5"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                    
                    <Button
                        android:id="@+id/tabOrders"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="2dp"
                        android:layout_marginRight="2dp"
                        android:text="🧾 उधारी"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:background="#E0E0E0"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                    
                    <Button
                        android:id="@+id/tabAnalytics"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="4dp"
                        android:text="📈 रिपोर्ट"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:background="#E0E0E0"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <!-- Filter Section -->
                <LinearLayout
                    android:id="@+id/filterBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <EditText
                            android:id="@+id/etSearchName"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1.2"
                            android:layout_marginRight="8dp"
                            android:hint="🔍 नाम खोजें..."
                            android:textSize="13sp"
                            android:background="@android:drawable/edit_text"
                            android:padding="8dp"
                            android:inputType="text" />

                        <Spinner
                            android:id="@+id/spDateFilter"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1.2" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/customDateRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">
                        
                        <Button
                            android:id="@+id/btnFromDate"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginRight="8dp"
                            android:text="शुरु: चुनें"
                            android:textSize="11sp"
                            android:background="#E0E0E0"
                            android:textColor="#000000"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                        <Button
                            android:id="@+id/btnToDate"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="अंत: चुनें"
                            android:textSize="11sp"
                            android:background="#E0E0E0"
                            android:textColor="#000000"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dashDynamicContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="100dp" />
            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnFloatingCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="🛒 कार्ट (0)"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="13sp"
            android:background="#03DAC5"
            android:padding="12dp"
            android:elevation="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </FrameLayout>
</LinearLayout>
