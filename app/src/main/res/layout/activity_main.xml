<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ═══ PREMIUM HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="श्री मिष्ठान भंडार"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  स्मार्ट बिलिंग सिस्टम"
                android:textColor="#A5B4FC"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_manage"
                android:scaleType="centerInside"
                android:tint="#FFFFFF"
                android:contentDescription="Settings"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ TOP NAV ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnShopView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginRight="4dp"
            android:text="🛍️ दुकान"
            android:textColor="#4F46E5"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/tab_active_bg"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btnDashView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:text="📊 डैशबोर्ड"
            android:textColor="@color/text_medium"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#00000000"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- ═══ CONTENT ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Shop View -->
        <ScrollView
            android:id="@+id/shopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="14dp"
            android:background="@color/bg_page">

            <LinearLayout
                android:id="@+id/shopProductList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="110dp" />
        </ScrollView>

        <!-- Dashboard View -->
        <ScrollView
            android:id="@+id/dashboardContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="14dp"
            android:background="@color/bg_page">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Dashboard Tab Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg"
                    android:padding="6dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="3dp">

                    <Button
                        android:id="@+id/tabInventory"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginRight="3dp"
                        android:text="💰 रेट"
                        android:textSize="12sp"
                        android:textColor="#4F46E5"
                        android:background="@drawable/tab_active_bg"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <Button
                        android:id="@+id/tabOrders"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="3dp"
                        android:layout_marginRight="3dp"
                        android:text="🧾 ऑर्डर्स"
                        android:textSize="12sp"
                        android:textColor="@color/text_medium"
                        android:background="#00000000"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <Button
                        android:id="@+id/tabAnalytics"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="3dp"
                        android:text="📈 रिपोर्ट"
                        android:textSize="12sp"
                        android:textColor="@color/text_medium"
                        android:background="#00000000"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <!-- Filter Bar -->
                <LinearLayout
                    android:id="@+id/filterBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="3dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etSearchName"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1.2"
                            android:layout_marginRight="8dp"
                            android:hint="🔍 नाम खोजें..."
                            android:textSize="13sp"
                            android:background="@drawable/input_bg"
                            android:padding="10dp"
                            android:inputType="text" />

                        <Spinner
                            android:id="@+id/spDateFilter"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1.2"
                            android:background="@drawable/input_bg"
                            android:padding="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/customDateRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btnFromDate"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginRight="6dp"
                            android:text="📅 शुरु"
                            android:textSize="12sp"
                            android:background="@drawable/input_bg"
                            android:textColor="@color/text_dark"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                        <Button
                            android:id="@+id/btnToDate"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="📅 अंत"
                            android:textSize="12sp"
                            android:background="@drawable/input_bg"
                            android:textColor="@color/text_dark"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dashDynamicContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="110dp" />
            </LinearLayout>
        </ScrollView>

        <!-- Premium FAB Cart -->
        <Button
            android:id="@+id/btnFloatingCart"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="18dp"
            android:text="🛒  कार्ट (0)"
            android:textColor="#1E1B4B"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/fab_cart"
            android:paddingLeft="22dp"
            android:paddingRight="22dp"
            android:elevation="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </FrameLayout>
</LinearLayout>
