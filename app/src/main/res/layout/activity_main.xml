<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8EC"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#5B1A2B"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="श्री मिष्ठान भंडार"
                android:textColor="#FBD9A8"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ताज़ी मिठाई, हर दिन"
                android:textColor="#FFF8EC"
                android:textSize="12sp"
                android:alpha="0.75" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#3F0F1C"
            android:padding="2dp">
            <Button
                android:id="@+id/btnShopView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️ दुकान"
                android:textSize="12sp"
                android:backgroundTint="#E8871E"
                android:textColor="#3F0F1C" />
            <Button
                android:id="@+id/btnDashView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 डैशबोर्ड"
                android:textSize="12sp"
                android:backgroundTint="#5B1A2B"
                android:textColor="#FFF8EC" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/shopContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
            <LinearLayout
                android:id="@+id/shopProductList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp" />
        </ScrollView>

        <ScrollView
            android:id="@+id/dashboardContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">
                    <Button android:id="@+id/tabInventory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦 इन्वेंट्री" android:textSize="11sp"/>
                    <Button android:id="@+id/tabOrders" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧾 ऑर्डर्स" android:textSize="11sp" android:layout_marginHorizontal="4dp"/>
                    <Button android:id="@+id/tabAnalytics" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊 Analytics" android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dashDynamicContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnFloatingCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:text="🛒 कार्ट (0)"
            android:backgroundTint="#E8871E"
            android:textColor="#3F0F1C"
            android:textStyle="bold" />
    </FrameLayout>
</LinearLayout>
